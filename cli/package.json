{
  "name": "@sdd/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "sdd": "./bin/run.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/commands/validate.ts src/commands/product/init.ts src/commands/product/scaffold.ts src/commands/gate/hygiene.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "@sdd/factory": "workspace:*",
    "@sdd/provenance": "workspace:*",
    "@sdd/schemas": "workspace:*",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "oclif": {
    "bin": "sdd",
    "dirname": "sdd",
    "commands": "./dist/commands",
    "topicSeparator": " "
  }
}
