{
  "name": "@sdd/schemas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./projects.schema.json": "./projects.schema.json",
    "./task.schema.json": "./task.schema.json",
    "./impact.schema.json": "./impact.schema.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "generated",
    "*.schema.json"
  ],
  "scripts": {
    "generate": "node scripts/generate-types.mjs",
    "build": "tsup src/index.ts src/validators.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist generated"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.5.0"
  }
}
